# Price Tracker - Environment Variables
# Copy this file to .env and fill in any values you want to enable.
#
#   cp .env.example .env
#
# All variables are optional. The tracker runs without .env:
# - Price drop alerts use macOS native notifications (osascript)
# - Notion logging is skipped if NOTION_* vars are unset

# Notion database logging (optional)
# Create an integration at https://www.notion.so/my-integrations
# Share your database with the integration, then paste token + database ID here.
NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id
